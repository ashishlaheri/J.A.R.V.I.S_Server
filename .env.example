# ═══════════════════════════════════════════════════════
#  J.A.R.V.I.S. v3.1 — Environment Configuration
#  Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════

# ── AI Provider ──────────────────────────────────────
# Options: groq (free, fast), gemini (free), openai (paid)
AI_PROVIDER=groq

# Groq (RECOMMENDED) — https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Google Gemini — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo

# ── Auth ─────────────────────────────────────────────
# Password for the web UI login
JARVIS_PASSWORD=jarvis

# JWT secret — change this to a random string!
JWT_SECRET=change-this-to-a-random-secret

# ── Weather ──────────────────────────────────────────
# Get a free key: https://openweathermap.org/api
OPENWEATHER_API_KEY=
WEATHER_CITY=Delhi

# ── Local Mode (jarvis.py only) ──────────────────────
WAKE_THRESHOLD=0.5
GITHUB_TOKEN=
MUSIC_DIR=C:\Users\yoash\Music\rock
WEBSITE_SAVE_DIR=C:\Users\yoash\Desktop\jarvis_websites

# ── Advanced ─────────────────────────────────────────
# MIC_INTERRUPT_THRESHOLD=3000
# TTS_VOICE=en-GB-RyanNeural
