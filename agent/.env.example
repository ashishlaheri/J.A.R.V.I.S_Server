# J.A.R.V.I.S. Local Agent Configuration
# ─────────────────────────────────────────
# Get your server URL from: sudo journalctl -u cloudflared --no-pager | grep "trycloudflare.com"
# Get your JWT token by logging into the web UI and checking localStorage for 'jarvis_token'

# Server WebSocket URL (use wss:// for Cloudflare, ws:// for local)
JARVIS_SERVER=wss://your-cloudflare-url.trycloudflare.com/ws

# JWT auth token (get this from the web UI login)
JARVIS_TOKEN=your_jwt_token_here
